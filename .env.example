# Database — use DATABASE_URL if set, otherwise the DB_* vars below
# DATABASE_URL=postgresql://user:password@localhost:5432/mrj
DB_NAME=mrj
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Cache (uses a separate Redis DB to avoid collision with Celery)
REDIS_URL=redis://localhost:6379/1

# AI (optional — add when integrating LLM features)
ANTHROPIC_API_KEY=

# Production only
DJANGO_SECRET_KEY=
FIELD_ENCRYPTION_KEY=
FORWARDED_FOR_TRUSTED_PROXY_COUNT=1
AUDIT_LOG_ADMIN_IMMUTABLE=true
ALLOWED_HOSTS=yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Optional: auto-create superuser on setup.sh --with-db
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=
