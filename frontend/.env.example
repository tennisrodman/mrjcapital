# Default data mode for a fresh browser. "true" starts in Demo mode
# (in-memory mock data, no backend writes); "false" starts in Live mode.
# Users can switch at runtime with the Demo/Live toggle.
VITE_USE_MOCKS=true

# Base URL of the Django API used in Live mode. Leave blank for local dev so
# requests use the Vite /api proxy from http://localhost:3000 to Django on :8000.
# Set this only for a deployed/non-proxied backend.
# REACT_APP_API_URL=
